# ============================================
# AI Expert System - Backend Environment
# ============================================
# 注意：本檔案為範本，啟動腳本會自動複製為 .env
# 實際設定請編輯專案根目錄的 .env 檔案
# backend/config.py 從專案根目錄的 .env 載入設定

# API 配置 (企業 API Proxy 統一端點)
OPENAI_BASE_URL=http://innoai.cminl.oa/agency/proxy/openai/platform

# 檔案路徑 (相對於 backend/)
RAW_FILES_DIR=data/raw_files
ARCHIVED_FILES_DIR=data/archived_files
GENERATED_MD_DIR=data/generated_md
FAILED_FILES_DIR=data/failed_files

# 檔案監控
ENABLE_FILE_WATCHER=true
WATCHER_DEBOUNCE_SECONDS=2
WATCHER_POLL_INTERVAL=1

# 資料庫
DB_PATH=data/documents/knowledge_v2.db
TOKEN_DB_PATH=data/documents/tokenrecord_v2.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# 安全設定
ENABLE_API_AUTH=false
SYSTEM_API_KEY=

# Session 設定
SESSION_TTL=86400
SESSION_MAX_TTL=604800

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500
ADMIN_RATE_LIMIT_PER_MINUTE=100

# Input 驗證
MAX_QUERY_LENGTH=2000
MAX_FILE_SIZE_MB=50
